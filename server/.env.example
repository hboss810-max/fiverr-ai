# ═══════════════════════════════════════════════════════
#  FIVERR AI SERVER — Environment Variables
#  Copy this file to .env and fill in your real values
# ═══════════════════════════════════════════════════════

# ── REQUIRED ────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── PAYMENTS (add when ready to accept money) ───────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── APP URLS ─────────────────────────────────────────────
# Your Vercel frontend URL (fill in after deploying frontend)
CLIENT_URL=https://your-app.vercel.app

# Server port (Railway sets this automatically)
PORT=3001
